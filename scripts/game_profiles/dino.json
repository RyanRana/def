{
  "state": [
    {
      "key": "player_x",
      "description": "T-Rex X position",
      "js_expression": "Runner.instance_.tRex.xPos",
      "type": "number"
    },
    {
      "key": "player_y",
      "description": "T-Rex Y position",
      "js_expression": "Runner.instance_.tRex.yPos",
      "type": "number"
    },
    {
      "key": "player_status",
      "description": "T-Rex animation status (WAITING, RUNNING, JUMPING, CRASHED)",
      "js_expression": "Runner.instance_.tRex.status",
      "type": "string"
    },
    {
      "key": "is_jumping",
      "description": "True if T-Rex is currently jumping",
      "js_expression": "Runner.instance_.tRex.jumping",
      "type": "boolean"
    },
    {
      "key": "current_speed",
      "description": "Current game speed",
      "js_expression": "Runner.instance_.currentSpeed",
      "type": "number"
    },
    {
      "key": "score",
      "description": "Current game score (displayed value)",
      "js_expression": "Runner.instance_.distanceMeter.getActualDistance(Runner.instance_.distanceRan)",
      "type": "number"
    },
    {
      "key": "high_score",
      "description": "Highest score achieved in this session",
      "js_expression": "Runner.instance_.highestScore",
      "type": "number"
    },
    {
      "key": "game_started",
      "description": "True if the game loop is active (not intro/waiting)",
      "js_expression": "Runner.instance_.started",
      "type": "boolean"
    },
    {
      "key": "game_crashed",
      "description": "True if the T-Rex has crashed (game over)",
      "js_expression": "Runner.instance_.crashed",
      "type": "boolean"
    },
    {
      "key": "game_paused",
      "description": "True if the game is currently paused",
      "js_expression": "Runner.instance_.paused",
      "type": "boolean"
    },
    {
      "key": "obstacle_count",
      "description": "Number of obstacles currently on screen",
      "js_expression": "Runner.instance_.horizon.obstacles.length",
      "type": "number"
    },
    {
      "key": "nearest_obstacle_x",
      "description": "X position of the nearest obstacle. -1 if no obstacles.",
      "js_expression": "Runner.instance_.horizon.obstacles.length > 0 ? Runner.instance_.horizon.obstacles[0].xPos : -1",
      "type": "number"
    },
    {
      "key": "nearest_obstacle_type",
      "description": "Type of the nearest obstacle ('CACTUS_SMALL', 'CACTUS_LARGE'). 'NONE' if no obstacles.",
      "js_expression": "Runner.instance_.horizon.obstacles.length > 0 ? Runner.instance_.horizon.obstacles[0].typeConfig.type : 'NONE'",
      "type": "string"
    }
  ],
  "mods": [
    {
      "key": "game_initial_speed",
      "label": "Initial Game Speed",
      "description": "The speed at which the game starts. Also resets current speed on restart.",
      "js_get": "Runner.instance_.config.SPEED",
      "js_set": "Runner.instance_.updateConfigSetting('SPEED', VALUE)",
      "default": 6,
      "min": 1,
      "max": 20,
      "step": 1,
      "category": "speed"
    },
    {
      "key": "game_max_speed",
      "label": "Max Game Speed",
      "description": "The maximum speed the game can reach as score increases.",
      "js_get": "Runner.instance_.config.MAX_SPEED",
      "js_set": "Runner.instance_.config.MAX_SPEED = VALUE",
      "default": 12,
      "min": 5,
      "max": 30,
      "step": 1,
      "category": "speed"
    },
    {
      "key": "game_speed_acceleration",
      "label": "Speed Acceleration",
      "description": "Rate at which the game speed increases over time, making it harder.",
      "js_get": "Runner.instance_.config.ACCELERATION",
      "js_set": "Runner.instance_.config.ACCELERATION = VALUE",
      "default": 0.001,
      "min": 0,
      "max": 0.01,
      "step": 0.0001,
      "category": "speed"
    },
    {
      "key": "gravity",
      "label": "Gravity Strength",
      "description": "Strength of gravity affecting T-Rex's jumps. Higher values mean faster falls.",
      "js_get": "Runner.instance_.config.GRAVITY",
      "js_set": "Runner.instance_.updateConfigSetting('GRAVITY', VALUE)",
      "default": 0.6,
      "min": 0.1,
      "max": 2,
      "step": 0.1,
      "category": "gravity"
    },
    {
      "key": "initial_jump_velocity",
      "label": "Initial Jump Velocity",
      "description": "The initial upward velocity when T-Rex jumps. Higher values mean higher jumps.",
      "js_get": "Runner.instance_.config.INITIAL_JUMP_VELOCITY",
      "js_set": "Runner.instance_.updateConfigSetting('INITIAL_JUMP_VELOCITY', VALUE)",
      "default": 12,
      "min": 5,
      "max": 25,
      "step": 1,
      "category": "gravity"
    },
    {
      "key": "min_jump_height",
      "label": "Minimum Jump Height",
      "description": "Minimum vertical distance T-Rex must clear before being able to fall, even if jump key is released.",
      "js_get": "Runner.instance_.config.MIN_JUMP_HEIGHT",
      "js_set": "Runner.instance_.updateConfigSetting('MIN_JUMP_HEIGHT', VALUE)",
      "default": 35,
      "min": 10,
      "max": 100,
      "step": 5,
      "category": "gravity"
    },
    {
      "key": "speed_drop_coefficient",
      "label": "Duck Speed Drop",
      "description": "Multiplier for how fast T-Rex falls when ducking (speed drop active).",
      "js_get": "Runner.instance_.config.SPEED_DROP_COEFFICIENT",
      "js_set": "Runner.instance_.updateConfigSetting('SPEED_DROP_COEFFICIENT', VALUE)",
      "default": 3,
      "min": 1,
      "max": 10,
      "step": 0.5,
      "category": "gravity"
    },
    {
      "key": "obstacle_gap_coefficient",
      "label": "Obstacle Gap Coefficient",
      "description": "Influences the randomized gap between obstacles. Higher values tend to create larger gaps.",
      "js_get": "Runner.instance_.config.GAP_COEFFICIENT",
      "js_set": "Runner.instance_.config.GAP_COEFFICIENT = VALUE",
      "default": 0.6,
      "min": 0.1,
      "max": 2,
      "step": 0.1,
      "category": "obstacle"
    },
    {
      "key": "obstacle_start_clear_time",
      "label": "Obstacle Start Clear Time",
      "description": "Time in milliseconds after game start before obstacles begin to appear.",
      "js_get": "Runner.instance_.config.CLEAR_TIME",
      "js_set": "Runner.instance_.config.CLEAR_TIME = VALUE",
      "default": 3000,
      "min": 0,
      "max": 10000,
      "step": 500,
      "category": "difficulty"
    },
    {
      "key": "score_coefficient",
      "label": "Score Multiplier",
      "description": "Converts raw distance run into the displayed score. Higher values mean faster score accumulation.",
      "js_get": "DistanceMeter.config.COEFFICIENT",
      "js_set": "DistanceMeter.config.COEFFICIENT = VALUE",
      "default": 0.025,
      "min": 0.005,
      "max": 0.1,
      "step": 0.005,
      "category": "reward"
    },
    {
      "key": "achievement_distance",
      "label": "Achievement Distance",
      "description": "The score interval at which an achievement (score flash and sound) is triggered.",
      "js_get": "DistanceMeter.config.ACHIEVEMENT_DISTANCE",
      "js_set": "DistanceMeter.config.ACHIEVEMENT_DISTANCE = VALUE",
      "default": 100,
      "min": 10,
      "max": 500,
      "step": 10,
      "category": "reward"
    },
    {
      "key": "gameover_clear_time",
      "label": "Game Over Restart Delay",
      "description": "Time in milliseconds required to pass after game over before a restart is allowed.",
      "js_get": "Runner.instance_.config.GAMEOVER_CLEAR_TIME",
      "js_set": "Runner.instance_.config.GAMEOVER_CLEAR_TIME = VALUE",
      "default": 750,
      "min": 0,
      "max": 2000,
      "step": 50,
      "category": "forgiveness"
    }
  ],
  "engagement_mod_keys": [
    "game_initial_speed",
    "game_max_speed",
    "game_speed_acceleration",
    "gravity",
    "initial_jump_velocity",
    "obstacle_gap_coefficient",
    "score_coefficient",
    "gameover_clear_time"
  ]
}